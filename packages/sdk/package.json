{
  "name": "@proofpoll/sdk",
  "version": "0.2.0",
  "description": "Collect verified-human survey responses with instant cUSD rewards on Celo (ProofPoll).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "celo",
    "celo-sepolia",
    "self-protocol",
    "minipay",
    "survey",
    "proof-of-personhood",
    "cusd",
    "viem"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:abi": "node scripts/gen-abi.mjs"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
