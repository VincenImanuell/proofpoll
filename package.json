{
  "name": "proofpoll",
  "version": "0.3.0",
  "private": true,
  "description": "Stripe-for-verified-human-surveys on Celo/MiniPay — escrowed cUSD rewards for unique, Self-verified humans.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "forge build --root contracts",
    "test": "forge test --root contracts",
    "fmt": "forge fmt --root contracts",
    "fmt:check": "forge fmt --check --root contracts",
    "lint:contracts": "forge lint --root contracts",
    "sdk:build": "pnpm --filter @proofpoll/sdk build",
    "sdk:test": "pnpm --filter @proofpoll/sdk test",
    "sdk:typecheck": "pnpm --filter @proofpoll/sdk typecheck",
    "react:build": "pnpm --filter @proofpoll/sdk build && pnpm --filter @proofpoll/react build",
    "react:test": "pnpm --filter @proofpoll/react test",
    "react:typecheck": "pnpm --filter @proofpoll/react typecheck",
    "packages:build": "pnpm --filter @proofpoll/sdk build && pnpm --filter @proofpoll/react build",
    "gen:abi": "forge build --root contracts && pnpm --filter @proofpoll/sdk gen:abi"
  }
}
