# Copy to .env and fill in. Never commit the real .env.

# RPC endpoints
CELO_SEPOLIA_RPC=https://forno.celo-sepolia.celo-testnet.org
CELO_MAINNET_RPC=https://forno.celo.org

# Celoscan API key (contract verification). Blockscout verification needs no key.
CELOSCAN_API_KEY=

# Deploy config
# PAY_TOKEN defaults to Celo Sepolia cUSD when unset; set explicitly for mainnet.
PAY_TOKEN=
# App scope seed for the Self adapter (<= 31 ASCII chars), e.g. "proofpoll".
SELF_SCOPE_SEED=proofpoll
# Deployed IHumanVerifier (Self adapter) address — required by Deploy.s.sol (mainnet path).
VERIFIER=

# Deployer key — prefer `cast wallet`/a keystore over a raw key in env:
#   forge script script/DeployTestnet.s.sol --rpc-url celo_sepolia --broadcast \
#     --keystore <file> --sender <address>
PRIVATE_KEY=
