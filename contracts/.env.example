# Copy to .env and fill in. Never commit the real .env.

# RPC endpoints
CELO_ALFAJORES_RPC=https://alfajores-forno.celo-testnet.org
CELO_MAINNET_RPC=https://forno.celo.org

# Celoscan API key (contract verification)
CELOSCAN_API_KEY=

# Deploy config
# PAY_TOKEN defaults to Alfajores cUSD when unset; set explicitly for mainnet.
PAY_TOKEN=
# Deployed IHumanVerifier (Self adapter) address — required by Deploy.s.sol.
VERIFIER=

# Deployer key — prefer `cast wallet` / a keystore over a raw key in env.
PRIVATE_KEY=
